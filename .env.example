# Copia este archivo como ".env" y completa los valores

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-aqui-va-tu-clave

# --- Google Drive monitor ---
DRIVE_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs_ejemplo
POLL_INTERVAL=60

# --- Siigo Nube ---
# Registro en: https://developer.siigo.com
SIIGO_USERNAME=tu_email@empresa.com
SIIGO_ACCESS_KEY=tu_access_key_de_siigo
SIIGO_PARTNER_ID=tu_partner_id_de_siigo
